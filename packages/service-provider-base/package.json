{
  "name": "@tkey/service-provider-base",
  "version": "17.0.0",
  "description": "TKey Base Service Provider Module",
  "author": "Torus Labs",
  "homepage": "https://github.com/tkey/tkey#readme",
  "license": "MIT",
  "main": "dist/lib.cjs/index.js",
  "module": "dist/lib.esm/index.js",
  "unpkg": "dist/lib.esm/index.js",
  "jsdelivr": "dist/lib.esm/index.js",
  "types": "dist/lib.cjs/types/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tkey/tkey.git"
  },
  "scripts": {
    "test": "vitest run --config ../../test/shared/node.mocked.mts --coverage",
    "coverage": "vitest run --config ../../test/shared/node.mocked.mts --coverage",
    "coverage-production": "vitest run --config ../../test/shared/node.prod.mts --coverage",
    "test-development": "vitest run --config ../../test/shared/node.dev.mts",
    "test-production": "vitest run --config ../../test/shared/node.prod.mts",
    "test-debugger": "vitest run --config ../../test/shared/node.debug.mts --inspect-brk",
    "browser-tests:local-mocked": "vitest run --config ../../test/shared/browsers.mocked.mts",
    "browser-tests:local-dev": "vitest run --config ../../test/shared/browsers.dev.mts",
    "browser-tests:local-prod": "vitest run --config ../../test/shared/browsers.prod.mts",
    "browser-tests:cloud-mocked": "vitest run --config ../../test/shared/browsers.mocked.mts",
    "browser-tests:cloud-prod": "vitest run --config ../../test/shared/browsers.prod.mts",
    "dev": "rimraf dist/ && cross-env NODE_ENV=development torus-scripts build",
    "build": "rimraf dist/ && cross-env NODE_ENV=production torus-scripts build",
    "lint": "torus-scripts lint src test",
    "prepack": "npm run build",
    "pre-commit": "lint-staged"
  },
  "peerDependencies": {
    "@babel/runtime": "7.x"
  },
  "devDependencies": {
    "vitest": "4.0.17"
  },
  "dependencies": {
    "@tkey/common-types": "^17.0.0",
    "@toruslabs/metadata-helpers": "^8.2.0"
  },
  "bugs": {
    "url": "https://github.com/tkey/tkey/issues"
  },
  "lint-staged": {
    "!(*d).ts": [
      "npm run lint --",
      "prettier --write 'src/**/*.ts'"
    ]
  },
  "engines": {
    "node": ">=22.x",
    "npm": ">=10.x"
  },
  "gitHead": "4ff88f7fe92b8c85bd0bfde069cde2e56005faca"
}
