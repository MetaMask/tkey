{
  "name": "@tkey/seed-phrase",
  "version": "17.0.0",
  "description": "TKey Seed Phrase Module",
  "author": "Torus Labs",
  "homepage": "https://github.com/tkey/tkey#readme",
  "license": "MIT",
  "main": "dist/lib.cjs/index.js",
  "module": "dist/lib.esm/index.js",
  "unpkg": "dist/lib.esm/index.js",
  "jsdelivr": "dist/lib.esm/index.js",
  "types": "dist/lib.cjs/types/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tkey/tkey.git"
  },
  "scripts": {
    "test": "vitest run --config test/configs/node.config.mts",
    "coverage": "vitest run --config test/configs/node.config.mts --coverage",
    "coverage-production": "vitest run --config test/configs/node.prod.config.mts --coverage",
    "test-development": "vitest run --config test/configs/node.dev.config.mts",
    "test-production": "vitest run --config test/configs/node.prod.config.mts",
    "test-debugger": "vitest run --config test/configs/node.debug.config.mts --inspect-brk",
    "dev": "rimraf dist/ && cross-env NODE_ENV=development torus-scripts build",
    "build": "rimraf dist/ && cross-env NODE_ENV=production torus-scripts build",
    "lint": "torus-scripts lint src test",
    "prepack": "npm run build",
    "pre-commit": "lint-staged"
  },
  "bugs": {
    "url": "https://github.com/tkey/tkey/issues"
  },
  "peerDependencies": {
    "@babel/runtime": "7.x"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@scure/bip32": "^1.7.0",
    "@scure/bip39": "^1.6.0",
    "@tkey/common-types": "^17.0.0"
  },
  "lint-staged": {
    "!(*d).ts": [
      "npm run lint --",
      "prettier --write 'src/**/*.ts'"
    ]
  },
  "engines": {
    "node": ">=22.x",
    "npm": ">=10.x"
  },
  "gitHead": "4ff88f7fe92b8c85bd0bfde069cde2e56005faca"
}
