{
  "name": "@tkey/web-storage",
  "version": "17.0.0",
  "description": "TKey Web Storage Module",
  "author": "Torus Labs",
  "homepage": "https://github.com/tkey/tkey#readme",
  "license": "MIT",
  "main": "dist/lib.cjs/index.js",
  "module": "dist/lib.esm/index.js",
  "unpkg": "dist/lib.esm/index.js",
  "jsdelivr": "dist/lib.esm/index.js",
  "types": "dist/lib.cjs/types/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tkey/tkey.git"
  },
  "scripts": {
    "test:browser": "vitest run --config ../../test/shared/browsers.mocked.mts --project Chrome",
    "test": "vitest run --config ../../test/shared/browsers.mocked.mts --project Chrome --coverage",
    "coverage": "vitest run --config ../../test/shared/browsers.mocked.mts --coverage --project Chrome",
    "coverage-production": "vitest run --config ../../test/shared/browsers.prod.mts --coverage --project Chrome",
    "test-development": "vitest run --config ../../test/shared/browsers.dev.mts --project Chrome",
    "test-production": "vitest run --config ../../test/shared/browsers.prod.mts --project Chrome",
    "node-tests:local-mocked": "vitest run --config ../../test/shared/node.mocked.mts",
    "browser-tests:local-mocked": "vitest run --config ../../test/shared/browsers.mocked.mts --project Chrome",
    "browser-tests:local-dev": "vitest run --config ../../test/shared/browsers.dev.mts --project Chrome",
    "browser-tests:local-prod": "vitest run --config ../../test/shared/browsers.prod.mts --project Chrome",
    "browser-tests:cloud-mocked": "vitest run --config ../../test/shared/browsers.mocked.mts --project Chrome",
    "browser-tests:cloud-prod": "vitest run --config ../../test/shared/browsers.prod.mts --project Chrome",
    "test-debugger": "vitest run --config ../../test/shared/node.debug.mts --inspect-brk",
    "dev": "rimraf dist/ && cross-env NODE_ENV=development torus-scripts build",
    "build": "rimraf dist/ && cross-env NODE_ENV=production torus-scripts build",
    "lint": "torus-scripts lint src test",
    "prepack": "npm run build",
    "pre-commit": "lint-staged"
  },
  "peerDependencies": {
    "@babel/runtime": "7.x"
  },
  "dependencies": {
    "@tkey/common-types": "^17.0.0"
  },
  "devDependencies": {
    "vitest": "4.0.17",
    "@tkey/core": "^17.0.0",
    "@tkey/service-provider-base": "^17.0.0",
    "@tkey/storage-layer-torus": "^17.0.0",
    "@types/filesystem": "^0.0.36"
  },
  "bugs": {
    "url": "https://github.com/tkey/tkey/issues"
  },
  "lint-staged": {
    "!(*d).ts": [
      "npm run lint --",
      "prettier --write 'src/**/*.ts'"
    ]
  },
  "engines": {
    "node": ">=22.x",
    "npm": ">=10.x"
  },
  "gitHead": "4ff88f7fe92b8c85bd0bfde069cde2e56005faca"
}
